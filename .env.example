# Runtime provider selection
# DB_PROVIDER: mssql | postgres
# STORAGE_PROVIDER: local-public | supabase-storage
DB_PROVIDER=mssql
STORAGE_PROVIDER=local-public

# MSSQL runtime
# Preferred for current local development on Windows.
# Use MSSQL_CONNECTION_STRING in deployment environments.
MSSQL_CONNECTION_STRING=
LOCAL_SQLSERVER_INSTANCE=(localdb)\MSSQLLocalDB
LOCAL_SQLSERVER_DB=PhotoCaptionLocalApp

# Postgres runtime
# Required when DB_PROVIDER=postgres
POSTGRES_URL=

# Supabase project and storage
# Required when STORAGE_PROVIDER=supabase-storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Analysis provider
# ANALYSIS_PROVIDER: openai | mock
ANALYSIS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_TIMEOUT_MS=15000
OPENAI_MAX_RETRIES=2
